// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========= AUTH & ADMIN MODELS =========
enum Role {
  USER
  SHOP
  ADMIN
}

model User {
  id              Int             @id @default(autoincrement())
  email           String          @unique
  password        String
  name            String?
  role            Role            @default(USER)
  createdAt       DateTime        @default(now())
  isActive        Boolean         @default(true)
  products        Product[] 
  reviews         Review[]
  cart            Cart?
  reportsSent     Report[]        @relation("ReportedBy")
  reportsReceived Report[]        @relation("ReportedUser")
  orders          Order[]
}

model Report {
  id             Int            @id @default(autoincrement())
  title          String
  message        String?
  status         ReportStatus   @default(PENDING)
  priority       ReportPriority @default(MEDIUM)
  createdAt      DateTime       @default(now())
  reporterId     Int
  reporter       User           @relation(name: "ReportedBy", fields: [reporterId], references: [id])
  reportedUserId Int?
  reportedUser   User?          @relation(name: "ReportedUser", fields: [reportedUserId], references: [id])
}

enum ReportStatus {
  PENDING
  PROCESSING
  RESOLVED
}

enum ReportPriority {
  LOW
  MEDIUM
  HIGH
}

// ========= PRODUCT & VARIANT MODELS =========

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

// MODEL PRODUCT
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime @default(now())

  ownerId     Int
  owner       User     @relation(fields: [ownerId], references: [id])
  categoryId  Int
  category    Category @relation(fields: [categoryId], references: [id])

  reviews     Review[]
  
  images      ProductImage[]   
  variants    ProductVariant[] 
  
  attributes  Attribute[]
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String  
  isDefault Boolean @default(false) 

  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

model ProductVariant {
  id        Int     @id @default(autoincrement())
  sku       String? @unique
  price     Float   
  stock     Int     @default(0) 
  
  productId Int
  product   Product @relation(fields: [productId], references: [id])

  values    VariantValue[] 
  
  cartItems CartItem[]
  orderItems OrderItem[]
}

// --- (Attribute) ---


model Attribute {
  id        Int     @id @default(autoincrement())
  name      String  
  
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  
  values    AttributeValue[]
}

model AttributeValue {
  id          Int     @id @default(autoincrement())
  value       String  // "S", "M", "Đen", "Trắng"
  
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id])
  
  variants    VariantValue[]
}

model VariantValue {
  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  
  valueId   Int
  value     AttributeValue @relation(fields: [valueId], references: [id])

  @@id([variantId, valueId])
}

// ========= REVIEW =========
model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  productId Int
  product   Product  @relation(fields: [productId], references: [id])
  userId    Int
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, productId])
}

// ========= CART =========
model Cart {
  id        Int        @id @default(autoincrement())
  ownerId   Int        @unique
  owner     User       @relation(fields: [ownerId], references: [id])
  createdAt DateTime   @default(now())
  cartItems CartItem[]
}

// CART ITEM 
model CartItem {
  id       Int @id @default(autoincrement())
  quantity Int @default(1)

  cartId   Int
  cart     Cart    @relation(fields: [cartId], references: [id])

  variantId  Int
  variant    ProductVariant @relation(fields: [variantId], references: [id])
}

// ========= ORDER =========
enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPING
  DELIVERED
  CANCELLED
  AWAITING_PAYMENT
}

enum PaymentType {
  VNPAY
  CASH
}

model Order {
  id                    Int       @id @default(autoincrement())
  totalAmount           Float
  status                OrderStatus @default(PENDING)
  createdAt             DateTime  @default(now())
  shippingAddress       String
  shippingCity          String?
  shippingPhone         String
  recipientName         String
  paymentMethod         PaymentType
  estimatedDeliveryDate DateTime
  trackingCode          String?
  orderCode            String   @unique

  userId Int
  user   User @relation(fields: [userId], references: [id])
  items  OrderItem[]
}

// ORDER ITEM 
model OrderItem {
  id       Int   @id @default(autoincrement())
  quantity Int


// SNAPSHOT 
  productName String  
  variantName String  
  thumbnail   String? 
  price    Float 

  orderId Int
  order   Order @relation(fields: [orderId], references: [id])

  variantId Int
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}